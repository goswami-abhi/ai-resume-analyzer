# Flask Configuration
SECRET_KEY=super-secret-key-change-in-production
FLASK_ENV=development
PORT=5000

# MongoDB Configuration
# Local MongoDB: mongodb://localhost:27017/resume_analyzer
# MongoDB Atlas: mongodb+srv://<username>:<password>@cluster0.xxxx.mongodb.net/resume_analyzer?retryWrites=true&w=majority
MONGO_URI=mongodb://localhost:27017/resume_analyzer

# AI Model Provider Configuration ('groq' or 'openai')
AI_PROVIDER=groq

# API Keys
GROQ_API_KEY=your_groq_api_key_here
OPENAI_API_KEY=your_openai_api_key_here
